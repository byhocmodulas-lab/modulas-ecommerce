# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000

# ─── Auth (Clerk) ────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# ─── JWT (local auth fallback) ───────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=different_long_random_string_for_refresh_tokens
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Databases ───────────────────────────────────────────────
DATABASE_URL=postgresql://modulas:modulas_dev@localhost:5432/modulas
MONGODB_URI=mongodb://modulas:modulas_dev@localhost:27017/modulas?authSource=admin
REDIS_URL=redis://:modulas_dev@localhost:6379
ELASTICSEARCH_URL=http://localhost:9200

# ─── Vector Store ────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=modulas-products

# ─── AI ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Payments ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Storage (Cloudflare R2) ─────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=modulas-assets
R2_PUBLIC_URL=https://assets.modulas.com

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=hello@modulas.com

# ─── Analytics ───────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Monitoring ──────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── Video (Workshop) ────────────────────────────────────────
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
