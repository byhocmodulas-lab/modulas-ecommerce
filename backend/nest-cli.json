{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/gateway/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "tsconfig.json"
  },
  "monorepo": true,
  "root": "apps/gateway",
  "projects": {
    "gateway": {
      "type": "application",
      "root": "apps/gateway",
      "entryFile": "main",
      "sourceRoot": "apps/gateway/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    },
    "auth": {
      "type": "library",
      "root": "apps/auth",
      "entryFile": "auth.module",
      "sourceRoot": "apps/auth/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    },
    "catalog": {
      "type": "library",
      "root": "apps/catalog",
      "entryFile": "modules/products/products.module",
      "sourceRoot": "apps/catalog/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    },
    "orders": {
      "type": "library",
      "root": "apps/orders",
      "entryFile": "orders.module",
      "sourceRoot": "apps/orders/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    },
    "configurator": {
      "type": "library",
      "root": "apps/configurator",
      "entryFile": "configurator.module",
      "sourceRoot": "apps/configurator/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    },
    "affiliate": {
      "type": "library",
      "root": "apps/affiliate",
      "entryFile": "affiliate.module",
      "sourceRoot": "apps/affiliate/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    },
    "collab": {
      "type": "library",
      "root": "apps/collab",
      "entryFile": "collab.module",
      "sourceRoot": "apps/collab/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    },
    "workshop": {
      "type": "library",
      "root": "apps/workshop",
      "entryFile": "workshop.module",
      "sourceRoot": "apps/workshop/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    },
    "content": {
      "type": "library",
      "root": "apps/content",
      "entryFile": "content.module",
      "sourceRoot": "apps/content/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    },
    "seo": {
      "type": "library",
      "root": "apps/seo",
      "entryFile": "seo.module",
      "sourceRoot": "apps/seo/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    },
    "intel": {
      "type": "library",
      "root": "apps/intel",
      "entryFile": "intel.module",
      "sourceRoot": "apps/intel/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    },
    "vendor": {
      "type": "library",
      "root": "apps/vendor",
      "entryFile": "vendor.module",
      "sourceRoot": "apps/vendor/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    },
    "social": {
      "type": "library",
      "root": "apps/social",
      "entryFile": "social.module",
      "sourceRoot": "apps/social/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    },
    "ai": {
      "type": "library",
      "root": "apps/ai",
      "entryFile": "ai.module",
      "sourceRoot": "apps/ai/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
